# FinancialPulse v5 — Environment Variables

# ── Required for LLM adjudication layer ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: NewsAPI for more news sources ────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Optional: Alpha Vantage for extended price history ─────────────────────────
ALPHA_VANTAGE_KEY=your_alphavantage_key

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Optional: Email alerts ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM_EMAIL=alerts@financialpulse.ai

# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=fp5-change-this-in-production
FLASK_ENV=production

# ── SQLite (FinancialPulse history: signals, backtests, KPIs) ───────────────────
# Default: financialpulse.db next to this app. On Render with a disk mounted at /var/data:
#   FINANCIALPULSE_SQLITE_PATH=/var/data/financialpulse.db
#FINANCIALPULSE_SQLITE_PATH=/var/data/financialpulse.db

# ── PostgreSQL (optional — same DB as MarketMinds on Render, no paid disk needed) ─
# When MarketMinds sets MARKETMINDS_FP_EMBEDDED=1 and DATABASE_URL / MARKETMINDS_DATABASE_URL
# is Postgres, FinancialPulse uses that URL automatically (no extra flag required).
# Opt out of Postgres for FP only: FINANCIALPULSE_FORCE_SQLITE=1
# Explicit override: FINANCIALPULSE_DATABASE_URL=postgresql://...
# Short flag alias: FINANCIALPULSE_USE_MM_POSTGRES=1  (same as FINANCIALPULSE_USE_MARKETMINDS_POSTGRES=1)
#FINANCIALPULSE_USE_MARKETMINDS_POSTGRES=1
#FINANCIALPULSE_USE_MM_POSTGRES=1
#FINANCIALPULSE_FORCE_SQLITE=1
#FINANCIALPULSE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
