# FinancialPulse v5 — Environment Variables

# ── Required for LLM adjudication layer ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: NewsAPI for more news sources ────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Optional: Alpha Vantage for extended price history ─────────────────────────
ALPHA_VANTAGE_KEY=your_alphavantage_key

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Optional: Email alerts ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM_EMAIL=alerts@financialpulse.ai

# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=fp5-change-this-in-production
FLASK_ENV=production
