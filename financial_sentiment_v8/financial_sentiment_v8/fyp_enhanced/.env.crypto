# FinancialPulse v8 — Environment Variables
# ════════════════════════════════════════════════════════════════════════════

# ── LLM Adjudication (existing) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── News & Price APIs (existing) ─────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_KEY=your_alphavantage_key

# ── Alerts (existing) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM_EMAIL=alerts@financialpulse.ai

# ── App (existing) ───────────────────────────────────────────────────────────
SECRET_KEY=fp8-change-this-in-production
FLASK_ENV=production


# ════════════════════════════════════════════════════════════════════════════
#  CRYPTO TRADING (NEW)
# ════════════════════════════════════════════════════════════════════════════

# ── STEP 1: Start with paper trading (NO real money) ─────────────────────────
# Set to false ONLY when you have tested thoroughly
PAPER_TRADING=true
PAPER_CAPITAL=10000.0          # Virtual starting capital in USD

# ── STEP 2: Choose your exchange ─────────────────────────────────────────────
# Options: binance | bybit | kraken
CRYPTO_EXCHANGE=binance

# ── STEP 3: Exchange API Keys ─────────────────────────────────────────────────
# Binance
# Get from: https://www.binance.com/en/my/settings/api-management
# Required permissions: Enable Reading + Enable Spot & Margin Trading
# NEVER enable withdrawals on API key
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=false    # set true to use Binance testnet first

# Bybit (alternative to Binance)
# Get from: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false

# ── STEP 4: Auto-trading toggle ───────────────────────────────────────────────
# When true, the scheduler will auto-execute signals every 90 seconds
# START WITH false — use /api/crypto/trade endpoint manually first
AUTO_TRADE_ENABLED=false

# ── STEP 5: Risk controls ─────────────────────────────────────────────────────
# These are the defaults — all can be tuned
RISK_MIN_CONFIDENCE=0.60        # Only trade if model confidence >= 60%
RISK_MIN_SIGNAL_SCORE=0.30      # Only trade if composite score >= 0.30
RISK_PER_TRADE_PCT=1.5          # Risk 1.5% of capital per trade
RISK_SL_PCT=1.5                 # Stop-loss distance % from entry
RISK_TP_RATIO=2.0               # Take-profit = SL × 2.0  (R:R = 1:2)
RISK_MAX_OPEN_TRADES=5          # Max simultaneous open positions
RISK_MAX_CAPITAL_DEPLOY=0.80    # Never deploy > 80% of capital
RISK_COOLDOWN_MINUTES=60        # Wait 60 min between trades on same asset
RISK_HOLD_HOURS=24              # Auto-close position after 24h
